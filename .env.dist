# Application configuration
FRONTEND_URL=FRONTEND_URL
FRONTEND_BASE_URL=https://avocarbon-action-plan.azurewebsites.net
#FRONTEND_BASE_URL=http://localhost:5173
MAX_ATTACHMENT_SIZE_MB=10
ALLOWED_ATTACHMENT_EXTENSIONS=pdf,doc,docx,xls,xlsx,png,jpg,jpeg,txt,csv
OPENAI_API_KEY=
AI_ACTION_PLAN_MODEL=gpt-4.1-mini

# scheduler configuration
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Africa/Tunis
DAILY_REMINDERS_ENABLED=false
DAILY_REMINDER_HOUR=8
DAILY_REMINDER_MINUTE=0
DAILY_PRIORITY_RECALCULATION_HOUR=8
DAILY_PRIORITY_RECALCULATION_MINUTE=0
ESCALATION_CHECK_HOUR=8
ESCALATION_CHECK_MINUTE=10
ESCALATION_EMAILS_ENABLED=true

# database configuration
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_postgres_host
DB_PORT=5432
DB_NAME=your_db_name

# organisation hierarchy database configuration
# Use either ORGANISATION_DATABASE_URL or the individual ORGANISATION_DB_* values.
ORGANISATION_DATABASE_URL=
ORGANISATION_DB_USER=your_organisation_db_user
ORGANISATION_DB_PASSWORD=your_organisation_db_password
ORGANISATION_DB_HOST=your_organisation_postgres_host
ORGANISATION_DB_PORT=5432
ORGANISATION_DB_NAME=Organisation_DB

# email configuration
SMTP_USER=your_sender@avocarbon.com
SMTP_PASSWORD=your_smtp_password_or_app_password

# Microsoft 365 authenticated SMTP
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_AUTH_ENABLED=true
SMTP_TIMEOUT_SECONDS=30

# Alternative Microsoft 365 relay example:
# SMTP_HOST=avocarbon-com.mail.protection.outlook.com
# SMTP_PORT=25
# SMTP_USE_TLS=false
# SMTP_USE_SSL=false
# SMTP_AUTH_ENABLED=false
# SMTP_TIMEOUT_SECONDS=30

AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=action-plan-files
